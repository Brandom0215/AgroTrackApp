<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    
    <!-- Permisos de Bluetooth -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" android:usesPermissionFlags="neverForLocation" tools:targetApi="s" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" tools:targetApi="s" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/icono_ganadex"
        android:label="@string/app_name"
        android:roundIcon="@drawable/icono_ganadex"
        android:supportsRtl="true"
        android:theme="@style/Theme.AgroTrackApp">

        <activity
            android:name=".ui.auth.Splash"
            android:theme="@style/Theme.GanaDEX.Splash"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ui.main.MainActivity"
            android:exported="true" />
        <activity
            android:name=".ui.auth.LoginActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />
        <activity
            android:name=".ui.auth.RegisterActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />
        <activity
            android:name=".ui.auth.PerfilUsuarioActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />
        <activity
            android:name=".ui.animales.CrearAnimalActivity"
            android:exported="false" />
        <activity
            android:name=".ui.insumos.CrearInventarioActivity"
            android:exported="false" />
        <activity
            android:name=".ui.produccion.CarneProduccionActivity"
            android:exported="false" />
        <activity
            android:name=".ui.produccion.LecheProduccionActivity"
            android:exported="false" />
        <activity
            android:name=".ui.animales.LotesActivity"
            android:exported="false" />
        <activity
            android:name=".ui.animales.CrearLoteActivity"
            android:exported="false" />

        <!-- Widget de Alertas -->
        <receiver
            android:name=".ui.alertas.AlertasWidgetProvider"
            android:exported="false"
            android:label="Alertas AgroTrack">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/alertas_widget_info" />
        </receiver>

        <service
            android:name=".ui.alertas.AlertasWidgetService"
            android:permission="android.permission.BIND_REMOTEVIEWS" />
    </application>

</manifest>