<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/bg_light">

    <!-- Top App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        app:liftOnScroll="false"
        style="@style/Widget.MaterialComponents.AppBarLayout.PrimarySurface"
        app:elevation="0dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:gravity="center_vertical">

            <!-- Hamburger Menu Button -->
            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Menú"
                android:src="@drawable/ic_menu"
                app:tint="?attr/colorOnPrimary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="GanaDEX"
                android:textColor="?attr/colorOnPrimary"
                android:textSize="20sp"
                android:textStyle="bold" />

        </RelativeLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:clipToPadding="false"
        android:paddingBottom="80dp">

        <LinearLayout
            android:id="@+id/contentContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Cabecera de Bienvenida con Gradiente Moderno -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@android:color/transparent">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_dashboard_header"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@+id/ivHeaderCow">

                        <TextView
                            android:id="@+id/tvFincaNombreHome"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Finca: Cargando..."
                            android:textColor="?attr/colorOnPrimary"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvUsuarioActivoHome"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Productor: Cargando..."
                            android:textColor="?attr/colorOnPrimary"
                            android:alpha="0.9"
                            android:textSize="14sp"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>

                    <ImageView
                        android:id="@+id/ivHeaderCow"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/vaca"
                        app:tint="?attr/colorOnPrimary"
                        android:alpha="0.8"
                        android:contentDescription="Icono de finca" />

                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 1. Resumen del Hato Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Resumen del Hato"
                        android:textSize="16sp"
                        android:textColor="@color/md_theme_light_primary"
                        android:textStyle="bold" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp">

                        <LinearLayout
                            android:id="@+id/llMetricActive"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true">

                            <TextView
                                android:id="@+id/tvActiveAnimalsCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="36sp"
                                android:textColor="@color/md_theme_light_primary"
                                android:textStyle="bold"
                                android:includeFontPadding="false" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Animales Activos"
                                android:textColor="@color/text_gray"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <com.github.mikephil.charting.charts.PieChart
                            android:id="@+id/donutChart"
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            android:layout_centerInParent="true" />

                        <!-- Desglose / Leyendas -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:layout_toEndOf="@id/donutChart"
                            android:layout_marginStart="12dp">

                            <!-- Vacas (Verde) -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="4dp">
                                <View
                                    android:layout_width="8dp"
                                    android:layout_height="8dp"
                                    android:background="@drawable/punto_verde" />
                                <TextView
                                    android:id="@+id/tvVacasCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text=" Hembras: 0"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_gray" />
                            </LinearLayout>

                            <!-- Toros (Marrón) -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="4dp">
                                <View
                                    android:layout_width="8dp"
                                    android:layout_height="8dp"
                                    android:background="@drawable/punto_marron" />
                                <TextView
                                    android:id="@+id/tvTorosCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text=" Machos: 0"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_gray" />
                            </LinearLayout>

                            <!-- Terneros/Novillas (Peach) -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <View
                                    android:layout_width="8dp"
                                    android:layout_height="8dp"
                                    android:background="@drawable/punto_melocoton" />
                                <TextView
                                    android:id="@+id/tvTernerosCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text=" Total Registros: 0"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_gray" />
                            </LinearLayout>

                        </LinearLayout>

                    </RelativeLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 2. Estado de Salud y Alertas Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Estado de Salud y Alertas"
                        android:textSize="16sp"
                        android:textColor="@color/md_theme_light_primary"
                        android:textStyle="bold" />

                    <!-- Alertas del Día en Tarjeta Pill -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardAlertasHoy"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#FFF3E0">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="12dp"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_alertas"
                                app:tint="#E65100"
                                android:contentDescription="Alerta" />

                            <TextView
                                android:id="@+id/tvAlertsCountHome"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sin alertas pendientes hoy"
                                android:textColor="#E65100"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:layout_marginStart="10dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Estado de Cuarentena en Tarjeta Pill -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardCuarentenaHome"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="@color/status_red_light">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="12dp"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_alertas"
                                app:tint="@color/status_red"
                                android:contentDescription="Alerta cuarentena" />

                            <TextView
                                android:id="@+id/tvCuarentenaCountHome"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sin animales bajo tratamiento o aislados"
                                android:textColor="@color/status_red"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:layout_marginStart="10dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 3. Rendimiento y Producción Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProduccion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rendimiento y Producción"
                        android:textSize="16sp"
                        android:textColor="@color/md_theme_light_primary"
                        android:textStyle="bold" />

                    <!-- Mini Gráfico de Líneas -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.2"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Producción semanal"
                                android:textSize="12sp"
                                android:textColor="@color/text_gray" />

                            <TextView
                                android:id="@+id/tvProduccionHome"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 Ltrs"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="@color/md_theme_light_primary"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <ImageView
                            android:layout_width="0dp"
                            android:layout_height="70dp"
                            android:layout_weight="1.8"
                            android:src="@drawable/grafica_produccion"
                            android:scaleType="fitCenter"
                            android:contentDescription="Grafico de produccion" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp" />

                    <!-- Ganancia de Peso -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_tendencia_arriba"
                            app:tint="@color/md_theme_light_primary"
                            android:contentDescription="Tendencia" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="GDP promedio (último pesaje):"
                            android:textColor="@color/text_gray"
                            android:textSize="13sp"
                            android:layout_marginStart="8dp" />

                        <TextView
                            android:id="@+id/tvGdpHome"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" 0.0 kg/día"
                            android:textColor="@color/md_theme_light_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 4. Alerta de Bajas Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Alerta de Bajas"
                        android:textSize="16sp"
                        android:textColor="@color/md_theme_light_primary"
                        android:textStyle="bold" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#E8F5E9">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="12dp"
                            android:gravity="center_vertical">

                             <TextView
                                 android:id="@+id/tvMortalidadHome"
                                 android:layout_width="wrap_content"
                                 android:layout_height="wrap_content"
                                 android:text="Tasa de mortalidad: 0.0% 📉"
                                 android:textColor="@color/md_theme_light_primary"
                                 android:textSize="15sp"
                                 android:textStyle="bold" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Disminución del 0.3% con respecto al mes anterior."
                        android:textColor="@color/text_gray"
                        android:textSize="12sp"
                        android:layout_marginTop="6dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 5. Inventario Crítico Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Inventario Crítico"
                        android:textSize="16sp"
                        android:textColor="@color/md_theme_light_primary"
                        android:textStyle="bold" />

                    <!-- Alerta Roja: Concentrado -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardCriticalInv1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="@color/status_red_light">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="12dp">
                            
                            <View
                                android:layout_width="6dp"
                                android:layout_height="20dp"
                                android:background="@color/status_red" />
                            
                            <TextView
                                android:id="@+id/tvCriticalInv1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Inventario en niveles óptimos"
                                android:textColor="@color/status_red"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:layout_marginStart="10dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Alerta Amarilla: Vacunas -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardCriticalInv2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#FFF9C4">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="12dp">
                            
                            <View
                                android:layout_width="6dp"
                                android:layout_height="20dp"
                                android:background="#F57F17" />
                            
                            <TextView
                                android:id="@+id/tvCriticalInv2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="No hay alertas preventivas"
                                android:textColor="#F57F17"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:layout_marginStart="10dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 6. Resumen Financiero Simple Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Resumen Financiero"
                        android:textSize="16sp"
                        android:textColor="@color/md_theme_light_primary"
                        android:textStyle="bold" />

                    <!-- Columnas de Ingresos vs Gastos -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp"
                        android:weightSum="2">

                        <!-- Ingresos (Verde) -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp"
                            app:cardCornerRadius="12dp"
                            app:cardBackgroundColor="#E8F5E9">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="INGRESOS MES"
                                    android:textSize="11sp"
                                    android:textColor="@color/md_theme_light_primary"
                                    android:textStyle="bold" />

                                 <TextView
                                     android:id="@+id/tvIngresosHome"
                                     android:layout_width="wrap_content"
                                     android:layout_height="wrap_content"
                                     android:text="$0.00"
                                     android:textSize="18sp"
                                     android:textStyle="bold"
                                     android:textColor="@color/md_theme_light_primary"
                                     android:layout_marginTop="4dp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Gastos (Rojo) -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp"
                            app:cardCornerRadius="12dp"
                            app:cardBackgroundColor="#FFEBEE">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="GASTOS MES"
                                    android:textSize="11sp"
                                    android:textColor="@color/status_red"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvGastosHome"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="$0.00"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/status_red"
                                    android:layout_marginTop="4dp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                    <!-- Ratio de Balance -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="16dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView
                                android:id="@+id/tvBalanceHome"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Balance neto: $0.00"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@color/md_theme_light_primary" />
                            <TextView
                                android:id="@+id/tvGastadoPercentHome"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="0% Gastado"
                                android:textSize="11sp"
                                android:textColor="@color/text_gray" />
                        </RelativeLayout>

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressBalanceHome"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            app:trackColor="#E0E0E0"
                            app:indicatorColor="@color/md_theme_light_primary"
                            android:value="0"
                            app:trackCornerRadius="4dp"
                            app:trackThickness="6dp"/>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>



</androidx.coordinatorlayout.widget.CoordinatorLayout>
