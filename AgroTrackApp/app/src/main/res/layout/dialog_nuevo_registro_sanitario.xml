<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bottom_sheet_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nuevo Registro Sanitario"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#2D3748"
            android:layout_marginBottom="16dp"/>

        <!-- ALCANCE -->
        <RadioGroup
            android:id="@+id/rgAlcance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">
            <RadioButton
                android:id="@+id/rbIndividual"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Individual"
                android:checked="true"/>
            <RadioButton
                android:id="@+id/rbMasivo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Masivo (Manga)"
                android:layout_marginStart="16dp"/>
        </RadioGroup>

        <!-- IDENTIFICADOR -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Identificador (Arete / Manga)"
            android:layout_marginBottom="12dp">
            <AutoCompleteTextView
                android:id="@+id/etIdentificador"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- CATEGORÍA -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Categoría"
            android:layout_marginBottom="12dp">
            <AutoCompleteTextView
                android:id="@+id/spCategoria"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                app:simpleItems="@array/sanitaria_categorias"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- SECCION VACUNACION -->
        <LinearLayout
            android:id="@+id/llVacunacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nombre de la Vacuna"
                android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etVacuna"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLength="15"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- SECCION TRATAMIENTO -->
        <LinearLayout
            android:id="@+id/llTratamiento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Tipo de Tratamiento"
                android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTipoTratamiento"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLength="15"/>
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Propósito"
                android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPropositoTratamiento"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLength="15"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- SECCION MASTITIS -->
        <LinearLayout
            android:id="@+id/llMastitis"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cuartos afectados:"
                android:textColor="#4A5568"
                android:layout_marginBottom="8dp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <CheckBox android:id="@+id/cbAD" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AD" android:layout_weight="1"/>
                <CheckBox android:id="@+id/cbPD" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PD" android:layout_weight="1"/>
                <CheckBox android:id="@+id/cbAI" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AI" android:layout_weight="1"/>
                <CheckBox android:id="@+id/cbPI" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PI" android:layout_weight="1"/>
            </LinearLayout>
        </LinearLayout>

        <!-- PRODUCTO COMUN -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilProductoComun"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Producto / Medicamento"
            android:layout_marginBottom="12dp"
            android:visibility="gone">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etProductoComun"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLength="15"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- DOSIS Y VETERINARIO -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Dosis"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDosis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLength="15"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Veterinario"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etVeterinario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapWords"
                android:maxLength="15"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- PLANIFICACIÓN -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Planificación"
            android:textSize="16sp"
            android:textColor="#2D3748"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tipo de repetición"
            android:layout_marginBottom="12dp">
            <AutoCompleteTextView
                android:id="@+id/spRepeticion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                app:simpleItems="@array/sanitaria_repeticiones"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ÚNICA: single date picker -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilFechaUnica"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Fecha de aplicación"
            app:endIconMode="custom"
            app:endIconDrawable="@android:drawable/ic_menu_my_calendar"
            android:layout_marginBottom="12dp"
            android:visibility="gone">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etFechaUnica"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:clickable="true"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- DIARIA / SEMANAL: dynamic checkboxes generated in code -->
        <LinearLayout
            android:id="@+id/llFechasContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp"
            android:visibility="gone"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGuardar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Guardar Registro"
            android:layout_marginTop="8dp"
            app:cornerRadius="8dp"
            android:backgroundTint="#48BB78"/>

    </LinearLayout>
</ScrollView>
