<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Carga Masiva de Leche"
        android:textColor="#1A5C38"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- Frecuencia Toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Frecuencia:"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginEnd="16dp" />

        <RadioGroup
            android:id="@+id/rgFrecuencia"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbDiario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Diario"
                android:checked="true"
                android:layout_marginEnd="8dp" />

            <RadioButton
                android:id="@+id/rbSemanal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Semanal" />
        </RadioGroup>
    </LinearLayout>

    <!-- Copiar de Ayer Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCopiarAyer"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Copiar producción de ayer"
        app:icon="@android:drawable/ic_menu_edit"
        android:textColor="#1A5C38"
        app:strokeColor="#1A5C38"
        android:layout_marginBottom="16dp" />

    <!-- Table Header labels -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#EEEEEE"
        android:padding="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Arete Vaca"
            android:textStyle="bold"
            android:textColor="#333333" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Litros a registrar"
            android:textStyle="bold"
            android:textColor="#333333"
            android:gravity="end" />
    </LinearLayout>

    <!-- Scrollable Matrix List -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:id="@+id/llMasivoContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />
    </ScrollView>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelMasivo"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancelar"
            android:textColor="#666666" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveMasivo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Guardar Lote"
            android:textColor="@android:color/white"
            app:backgroundTint="#1A5C38"
            android:layout_marginStart="8dp" />
    </LinearLayout>

</LinearLayout>
