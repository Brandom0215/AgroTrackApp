<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="?android:colorBackground">

    <!-- Top App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        app:liftOnScroll="false"
        style="@style/Widget.MaterialComponents.AppBarLayout.PrimarySurface"
        app:elevation="0dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="4dp"
            android:paddingEnd="16dp"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_back"
                app:tint="?attr/colorOnPrimary" />

            <TextView
                android:id="@+id/tvTitleActivity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Crear Animal"
                android:textColor="?attr/colorOnPrimary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- Icons on the right -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnBluetooth"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_bluetooth_white"
                    app:tint="?attr/colorOnPrimary" />
            </LinearLayout>

        </RelativeLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header Image with Camera Button -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="@drawable/bg_cow_header">

                <ImageView
                    android:id="@+id/ivAnimalPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="Vista previa de foto"
                    android:visibility="gone" />
                
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnCamera"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    app:cardCornerRadius="40dp"
                    app:cardBackgroundColor="#80000000"
                    app:strokeWidth="0dp"
                    android:clickable="true"
                    android:focusable="true">
                    
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_camera_alt"
                        app:tint="#4FC3F7" />

                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Modo de Registro Selector (Individual vs. Global/Lote) -->
                <TextView
                    android:id="@+id/tvModoRegistroHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Modo de Registro *"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/md_theme_light_primary"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:id="@+id/layoutModoRegistroSelector"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardModoIndividual"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="24dp"
                        app:cardBackgroundColor="#4FC3F7"
                        app:strokeWidth="0dp"
                        android:clickable="true"
                        android:focusable="true">

                         <TextView
                            android:id="@+id/tvLabelIndividual"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="Individual"
                            android:textColor="@android:color/white"
                            android:textStyle="bold" />
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardModoGlobal"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        app:cardCornerRadius="24dp"
                        app:cardBackgroundColor="?attr/colorSurface"
                        app:strokeColor="#E0E0E0"
                        app:strokeWidth="1dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/tvLabelGlobal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="Global (Lote)"
                            android:textColor="#9E9E9E"
                            android:textStyle="bold" />
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Contenedor de Tags Globales (Lote) -->
                <LinearLayout
                    android:id="@+id/layoutGlobalTags"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp"
                        app:strokeColor="@color/md_theme_light_primary"
                        app:strokeWidth="1dp"
                        app:cardBackgroundColor="#F1F8E9">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">

                                <TextView
                                    android:id="@+id/tvConexionBaston"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Bastón RFID: Desconectado"
                                    android:textStyle="bold"
                                    android:textColor="@color/text_gray"
                                    android:layout_alignParentStart="true"
                                    android:layout_centerVertical="true" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnConectarBaston"
                                    style="@style/Widget.Material3.Button.ElevatedButton"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_alignParentEnd="true"
                                    android:text="Conectar"
                                    android:textSize="12sp"
                                    app:cornerRadius="8dp" />

                            </RelativeLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/divider"
                                android:layout_marginVertical="12dp" />

                            <TextView
                                android:id="@+id/tvContadorTags"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tags Escaneados: 0"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/md_theme_light_primary" />

                            <TextView
                                android:id="@+id/tvListaTags"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Ningún tag escaneado aún. Conecte el bastón y simule escaneos."
                                android:textColor="#757575"
                                android:textSize="13sp"
                                android:layout_marginTop="8dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnLimpiarTags"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Limpiar Lista"
                                android:textColor="#E53935"
                                android:layout_gravity="end"
                                android:layout_marginTop="8dp"
                                android:visibility="gone" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Sex Toggle Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="16dp">
                    
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardMacho"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="24dp"
                        app:cardBackgroundColor="#4FC3F7"
                        app:strokeWidth="0dp"
                        android:clickable="true"
                        android:focusable="true">
                        
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/ic_camera_alt"
                                android:backgroundTint="#03A9F4"
                                android:gravity="center"
                                android:text="M"
                                android:textColor="@android:color/white"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="Macho"
                                android:textColor="@android:color/white"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                    
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardHembra"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        app:cardCornerRadius="24dp"
                        app:cardBackgroundColor="?attr/colorSurface"
                        app:strokeColor="#E0E0E0"
                        app:strokeWidth="1dp"
                        android:clickable="true"
                        android:focusable="true">
                        
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/ic_camera_alt"
                                android:backgroundTint="#9C27B0"
                                android:gravity="center"
                                android:text="H"
                                android:textColor="@android:color/white"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="Hembra"
                                android:textColor="#9E9E9E" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Arete -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilNumeroAnimal"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Arete *"
                    app:errorEnabled="true">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNumeroAnimal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:maxLength="4"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Trazabilidad -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilTrazabilidad"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Trazabilidad"
                    app:errorEnabled="true">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTrazabilidad"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:maxLength="4"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Número de chip -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilNumeroChip"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Número de chip"
                    app:errorEnabled="true">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNumeroChip"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:maxLength="4"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Información básica Header -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_section_header"
                    android:text="Información basica"
                    android:textColor="?attr/colorOnPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />


                <!-- Fecha de nacimiento -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilFechaNacimiento"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Fecha de nacimiento *"
                    app:errorEnabled="true">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etFechaNacimiento"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:clickable="true"
                        android:inputType="date" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Raza -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Raza *">
                    <AutoCompleteTextView
                        android:id="@+id/etRaza"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Propósito -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Propósito Animal *">
                    <AutoCompleteTextView
                        android:id="@+id/etProposito"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:text="Doble propósito" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Manga -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Manga (Lote)">
                    <AutoCompleteTextView
                        android:id="@+id/etManga"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Peso Header -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_section_header"
                    android:text="Peso (kg)"
                    android:textColor="?attr/colorOnPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <!-- Peso Input -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Peso (kg)">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPeso"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Origen Header -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_section_header"
                    android:text="Origen"
                    android:textColor="?attr/colorOnPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <!-- Origen Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:hint="Padre">
                        <AutoCompleteTextView
                            android:id="@+id/etPadre"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:hint="Madre">
                        <AutoCompleteTextView
                            android:id="@+id/etMadre"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Otros Header -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_section_header"
                    android:text="Otros"
                    android:textColor="?attr/colorOnPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <!-- Notas -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilNotas"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="32dp"
                    android:hint="Notas y observaciones"
                    app:errorEnabled="true"
                    app:counterEnabled="true"
                    app:counterMaxLength="100">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNotas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top|start"
                        android:inputType="textMultiLine"
                        android:maxLength="100"
                        android:lines="4"
                        android:minLines="4" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Crear Button -->
                <LinearLayout
                    android:id="@+id/llActionButtonsAnimal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="32dp">

                    <!-- Crear/Guardar Button (Left) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCrear"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="Crear"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:cornerRadius="28dp"
                        app:backgroundTint="?attr/colorPrimary"
                        android:textColor="@android:color/white" />

                    <!-- Delete Button (Only visible in edit mode, Right) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDeleteAnimal"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="Eliminar"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:cornerRadius="28dp"
                        app:backgroundTint="#D32F2F"
                        android:textColor="@android:color/white"
                        android:visibility="gone" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
