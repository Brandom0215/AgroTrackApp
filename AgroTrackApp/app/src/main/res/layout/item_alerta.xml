<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <View
            android:id="@+id/viewPrioridad"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@color/md_theme_light_primary"
            android:layout_marginEnd="16dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvAlertaTitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Título de la Alerta"
                android:textColor="?android:textColorPrimary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAlertaDescripcion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Descripción detallada de la alerta que se está mostrando."
                android:textColor="?android:textColorSecondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvAlertaFecha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="20/05/2024"
                android:textColor="?android:textColorSecondary"
                android:textSize="12sp"
                android:textStyle="italic" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnIr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="IR A GESTIÓN"
                android:textSize="11sp"
                android:textColor="@android:color/white"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:backgroundTint="#2E7D32"
                app:cornerRadius="24dp"
                app:icon="@drawable/ic_produccion"
                app:iconSize="14dp"
                app:iconTint="@android:color/white"
                app:paddingStart="12dp"
                app:paddingEnd="12dp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/ivAlertaIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center_vertical"
            android:src="@drawable/ic_alertas"
            app:tint="?attr/colorPrimary" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
