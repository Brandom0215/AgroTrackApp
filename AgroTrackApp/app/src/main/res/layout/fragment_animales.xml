<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/bg_light">

    <!-- AppBar Layout -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        android:background="?attr/colorPrimary" app:liftOnScroll="false" style="@style/Widget.MaterialComponents.AppBarLayout.PrimarySurface" app:elevation="0dp">
        
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">
            
            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_menu"
                app:tint="?attr/colorOnPrimary"
                android:contentDescription="Menú" />
                
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Gestión de Animales"
                android:textColor="?attr/colorOnPrimary"
                android:textStyle="bold"
                android:textSize="18sp" />

            <ImageButton
                android:id="@+id/btnToggleSearch"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_search"
                app:tint="?attr/colorOnPrimary"
                android:contentDescription="Buscar" />
        </RelativeLayout>

        <LinearLayout
            android:id="@+id/searchContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:padding="8dp"
            android:background="?attr/colorPrimary">
            
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSearchArete"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/bg_widget_rounded"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:hint="Buscar por arete..."
                android:textSize="14sp"
                android:textColor="@color/black"
                android:textColorHint="@color/text_gray"
                android:inputType="text" />
        </LinearLayout>


    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:clipToPadding="false"
        android:paddingBottom="80dp">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">



            <!-- Filtros Personalizados -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:orientation="horizontal"
                android:weightSum="3"
                android:baselineAligned="false">
                
                <!-- Machos -->
                <LinearLayout
                    android:id="@+id/llFilterMachos"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_filter_button_selector"
                    android:padding="4dp"
                    android:clickable="true"
                    android:focusable="true">
                    
                    <TextView
                        android:id="@+id/tvCountMachos"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_circle_solid"
                        android:backgroundTint="#03A9F4"
                        android:gravity="center"
                        android:text="0"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:textSize="14sp"/>
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Machos"
                        android:textColor="@color/text_gray"
                        android:textSize="13sp"
                        android:maxLines="1"
                        android:ellipsize="end"/>
                </LinearLayout>

                <!-- Hembras -->
                <LinearLayout
                    android:id="@+id/llFilterHembras"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_filter_button_selector"
                    android:padding="4dp"
                    android:clickable="true"
                    android:focusable="true">
                    
                    <TextView
                        android:id="@+id/tvCountHembras"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_circle_solid"
                        android:backgroundTint="#9C27B0"
                        android:gravity="center"
                        android:text="0"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:textSize="14sp"/>
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Hembras"
                        android:textColor="@color/text_gray"
                        android:textSize="13sp"
                        android:maxLines="1"
                        android:ellipsize="end"/>
                </LinearLayout>

                <!-- Lotes -->
                <LinearLayout
                    android:id="@+id/llFilterLotes"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_filter_button_selector"
                    android:padding="4dp"
                    android:clickable="true"
                    android:focusable="true">
                    
                    <TextView
                        android:id="@+id/tvCountLotes"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_circle_solid"
                        android:backgroundTint="#4CAF50"
                        android:gravity="center"
                        android:text="0"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:textSize="14sp"/>
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Lotes"
                        android:textColor="@color/text_gray"
                        android:textSize="13sp"
                        android:maxLines="1"
                        android:ellipsize="end"/>
                </LinearLayout>
            </LinearLayout>

            <!-- 3. Tabla de Animales Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Animales Registrados"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/md_theme_light_primary"
                        android:layout_marginBottom="12dp" />

                    <!-- Table Headers -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="4.0"
                        android:paddingVertical="8dp"
                        android:paddingHorizontal="8dp"
                        android:background="#F5F5F0">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.0"
                            android:text="Arete"
                            android:textColor="@color/md_theme_light_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.0"
                            android:text="Raza"
                            android:textColor="@color/md_theme_light_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.2"
                            android:text="Propósito"
                            android:textColor="@color/md_theme_light_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.8"
                            android:text="Acción"
                            android:textColor="@color/md_theme_light_primary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:gravity="center" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider" />

                    <!-- RecyclerView for Table Rows -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvAnimalesTabla"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        android:nestedScrollingEnabled="false" />

                    <!-- Empty state view -->
                    <TextView
                        android:id="@+id/tvEmptyState"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No hay animales registrados que coincidan con la búsqueda."
                        android:gravity="center"
                        android:padding="24dp"
                        android:textColor="@color/text_gray"
                        android:textSize="14sp"
                        android:visibility="gone" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 4. Activity List Card (Actividad Reciente) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:text="Actividad Reciente"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/md_theme_light_primary" />

                    <!-- Dynamic Activity Container -->
                    <LinearLayout
                        android:id="@+id/llRecentActivityContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvEmptyRecentActivity"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="No hay actividad reciente registrada."
                            android:gravity="center"
                            android:padding="16dp"
                            android:textColor="@color/text_gray"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Floating Action Button for adding animals -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddAnimal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        app:backgroundTint="?attr/colorPrimary"
        app:srcCompat="@android:drawable/ic_input_add"
        app:tint="@color/white"
        app:elevation="6dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
