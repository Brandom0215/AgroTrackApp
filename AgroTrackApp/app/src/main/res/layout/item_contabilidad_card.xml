<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp"
    app:strokeWidth="1dp"
    app:strokeColor="#EEEEEE"
    app:cardBackgroundColor="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Product Icon or Initial -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="#E8F0E8"
            app:strokeWidth="0dp">
            <ImageView
                android:id="@+id/ivIcono"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_produccion"
                app:tint="@color/md_theme_light_primary" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/tvNombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre del Producto"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/md_theme_light_onSurface" />

            <TextView
                android:id="@+id/tvStockInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stock: 180 Litros"
                android:textSize="12sp"
                android:textColor="@color/text_gray"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvCostoUnit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="C: $45.00"
                android:textSize="12sp"
                android:textColor="@color/status_red" />

            <TextView
                android:id="@+id/tvPrecioUnit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="P: $60.00"
                android:textSize="12sp"
                android:textColor="@color/md_theme_light_primary"
                android:layout_marginTop="1dp" />

            <TextView
                android:id="@+id/tvGanancia"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+$15.00"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/status_green"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
